# ================================================================
# WAPPA — ENVIRONMENT VARIABLE NAMING POLICY
# ================================================================
#
# Unprefixed platform contracts : PORT, DATABASE_URL, REDIS_URL
# Framework runtime settings    : SYSTEM_*
# Meta / WhatsApp transport     : META_*, WP_*
# AI vendor services            : OPENAI_*, ANTHROPIC_*
# Storage vendor services       : SUPABASE_*
# App-specific namespaces       : your own prefix (e.g. MIIA_*, BELLABELLA_*)
# ================================================================

# ── Platform ────────────────────────────────────────────────────
PORT=8000

# ── Framework (SYSTEM_*) ────────────────────────────────────────
SYSTEM_ENVIRONMENT=DEV
SYSTEM_LOG_LEVEL=DEBUG
SYSTEM_LOG_DIR=./logs
SYSTEM_TIME_ZONE=UTC

# ── Meta / WhatsApp ─────────────────────────────────────────────
META_API_VERSION=v25.0
WP_ACCESS_TOKEN=
WP_PHONE_ID=
WP_BID=
WP_WEBHOOK_VERIFY_TOKEN=

# ── Persistence (required for PubSub) ───────────────────────────
REDIS_URL=redis://localhost:6379/
REDIS_MAX_CONNECTIONS=64

# ── AI (uncomment to enable) ────────────────────────────────────
# OPENAI_API_KEY=
